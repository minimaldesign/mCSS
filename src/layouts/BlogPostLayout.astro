---
import BaseLayout from './BaseLayout.astro';

import arrow from '../assets/icons/mail.svg?raw';
import NewsletterSignup from '../components/_NewsletterSignup.astro';
import ReadProgressBar from '../components/ReadProgressBar.astro';
import Tags from '../components/Tags.astro';

const { frontmatter } = Astro.props;

// BlogPosting structured data (schema.org), built from the post frontmatter
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.pubDate.toISOString().slice(0, 10),
  author: {
    '@type': 'Person',
    name: frontmatter.author,
  },
  url: Astro.url.href,
  mainEntityOfPage: Astro.url.href,
  ...(frontmatter.image && { image: new URL(frontmatter.image.url, Astro.url.origin).href }),
});
---

<BaseLayout title={`${frontmatter.title} | mCSS Blog`} bodyClass="layout layout-centered" frontmatter={frontmatter} article={{ publishedTime: frontmatter.pubDate, author: frontmatter.author }}>
  <script is:inline type="application/ld+json" slot="head" set:html={jsonLd} />
  <ReadProgressBar />
  <main class="layout_content_main blog">
    <h1>{frontmatter.title}</h1>
    <div class="blog_meta">
      <p>
        Published on{' '}
        <time datetime={frontmatter.pubDate.toISOString().slice(0, 10)}>
          {
            frontmatter.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
      </p>
      <Tags tagList={frontmatter.tags} sort />
    </div>
    <div class="prose">
      <slot />
    </div>
    <a href={`mailto:hello@mcss.dev?subject=${encodeURIComponent(frontmatter.title)}`} class="bt bt-primary bt-lg mt-sm3">
      <Fragment set:html={arrow} /> Reply by email
    </a>
    <NewsletterSignup />
    <!-- <aside>
    <h3>Browse all tags</h3>
    <ul>
      {
        tags.map((tag) => (
          <li>
            <a href={`/blog/tags/${tag}`}>{tag}</a>
          </li>
        ))
      }
    </ul>
  </aside> -->
  </main>
</BaseLayout>
