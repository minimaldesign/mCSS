---
import type { HTMLAttributes } from 'astro/types';
import { slugify } from '../scripts/utilities';

// Props definitions
interface Props extends HTMLAttributes<'ul'> {
  tagList?: string[]; // Array of tag names
  variant?: 'inline' | 'list';
  url?: string;
  sort?: boolean; // opt-in alphabetical sorting; input order is preserved by default
  'data-testid'?: string;
  ariaLabel?: string;
}

// prettier-ignore
const {
  tagList = [],
  variant = 'inline',
  url = "/blog/tags",
  sort = false,
  class: className,
  'data-testid': testId = 'tags',
  ariaLabel = 'Tags',
  ...rest
} = Astro.props as Props;

const tags = sort ? [...tagList].sort((a, b) => a.localeCompare(b)) : tagList;

function joinUrl(base: string, tag: string) {
  return base.endsWith('/') ? `${base}${tag}` : `${base}/${tag}`;
}
---

{
  tags.length > 0 && (
    <nav aria-label={ariaLabel}>
      <ul class:list={['tags', { 'tags-inline': variant === 'inline' }, className]} data-testid={testId} {...rest}>
        {tags.map((tag) => (
          <li>
            <a href={joinUrl(url, slugify(tag))}>{tag}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
