---
import Nav from '../components/Nav.astro';
import NavMobile from '../components/NavMobile.astro';
import ThemeToggle from './ThemeToggle.astro';
import logoImg from '../assets/ui/mcss-logo.svg?raw';
---

<header class="header is-top">
  <a class="header_logo" href="/">
    <Fragment set:html={logoImg} /> mCSS
  </a>
  <Nav />
  <NavMobile />
  <div class="header_toggle">
    <ThemeToggle />
  </div>
</header>

<script>
  import { throttle } from '../scripts/utilities';

  function toggleClassOnScroll() {
    const header = document.querySelector('.header');
    if (!header) return;
    if (window.scrollY === 0) {
      header.classList.add('is-top');
    } else {
      header.classList.remove('is-top');
    }
  }
  // addEventListener (not window.onscroll =) so other scroll handlers survive
  window.addEventListener('scroll', throttle(toggleClassOnScroll, 100), { passive: true });
</script>
