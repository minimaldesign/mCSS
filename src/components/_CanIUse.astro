---
// @ts-nocheck
/**
 * Displays browser support for any web platform feature.
 *
 * Usage: <CanIUse feature="css.properties.mask-composite" />
 *
 * Dependencies (npm packages this component imports)
 * --------------------------------------------------
 *   npm install @mdn/browser-compat-data web-features caniuse-lite
 *
 * Finding the feature path
 * ------------------------
 * The `feature` prop is a dot-separated path into the MDN Browser Compat Data
 * (BCD) dataset. The easiest way to find it:
 *
 *   1. Open the MDN docs page for the feature, e.g.
 *      https://developer.mozilla.org/en-US/docs/Web/CSS/mask-composite
 *   2. Scroll to the "Browser compatibility" section and click "Source on GitHub".
 *      The URL will be something like:
 *      github.com/mdn/browser-compat-data/blob/main/css/properties/mask-composite.json
 *   3. Convert the file path to a dot-path, dropping the .json extension:
 *      css/properties/mask-composite.json → css.properties.mask-composite
 *
 * Common patterns:
 *   CSS property    → css.properties.<name>          e.g. css.properties.mask
 *   CSS selector    → css.selectors.<name>           e.g. css.selectors.has
 *   CSS at-rule     → css.at-rules.<name>            e.g. css.at-rules.container
 *   HTML element    → html.elements.<name>           e.g. html.elements.dialog
 *   JS built-in     → javascript.builtins.<path>     e.g. javascript.builtins.Array.at
 *   Web API         → api.<Interface>.<member>       e.g. api.IntersectionObserver
 */

import bcdData from '@mdn/browser-compat-data';
import { features as webFeatures } from 'web-features';
import { agents as localAgents } from 'caniuse-lite';
import externalLinkIcon from '../assets/icons/external-link.svg?raw';
import baselineLimitedIcon from '../assets/icons/baseline-limited.svg?raw';
import baselineNewlyIcon from '../assets/icons/baseline-newly.svg?raw';
import baselineWidelyIcon from '../assets/icons/baseline-widely.svg?raw';

function getBaselineLookup() {
  const g = globalThis;
  if (g.__baselineLookup) return g.__baselineLookup;
  const map = new Map();
  for (const [id, feat] of Object.entries(webFeatures)) {
    if (!('status' in feat) || !('name' in feat)) continue;
    const bl = feat.status?.baseline;
    const year = feat.status?.baseline_low_date?.split('-')[0];
    const entry = {
      id,
      name: feat.name,
      baseline: bl === 'high' ? 'high' : bl === 'low' ? 'low' : false,
      year,
    };
    for (const key of feat.compat_features ?? []) {
      map.set(key, entry);
    }
  }
  g.__baselineLookup = map;
  return map;
}

const BASELINE_ICONS = {
  limited: baselineLimitedIcon,
  low: baselineNewlyIcon,
  high: baselineWidelyIcon,
};

// Fetched once per build, shared across all component renders.
// Caches the Promise (not just the result) so concurrent renders
// that start before the first fetch resolves all share one request.
const CANIUSE_DB_URL = 'https://cdn.jsdelivr.net/npm/caniuse-db/data.json';

function getUsageAgents() {
  const g = globalThis;
  if (!g.__caniuseAgentsPromise) {
    g.__caniuseAgentsPromise = fetch(CANIUSE_DB_URL)
      .then((res) => {
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
      })
      .then((data) => {
        console.log('[CanIUse] fetched fresh usage data from caniuse-db');
        return data.agents;
      })
      .catch((e) => {
        console.warn(
          '[CanIUse] caniuse-db fetch failed, using bundled caniuse-lite:',
          e instanceof Error ? e.message : String(e),
        );
        return localAgents;
      });
  }
  return g.__caniuseAgentsPromise;
}

const { feature, title, mdnUrl: mdnUrlOverride } = Astro.props;

const usageAgents = await getUsageAgents();

const baselineLookup = getBaselineLookup();
const baselineInfo = baselineLookup.get(feature);
const baselineYamlUrl = baselineInfo
  ? `https://github.com/web-platform-dx/web-features/blob/main/features/${baselineInfo.id}.yml`
  : undefined;

// Navigate BCD tree by dot-path: "css.properties.mask-composite"
const parts = feature.split('.');
let node = bcdData;
for (const p of parts) node = node?.[p];
const compat = node?.__compat;

const featureName = title ?? baselineInfo?.name ?? parts[parts.length - 1];
const mdnUrl =
  mdnUrlOverride ??
  compat?.mdn_url ??
  `https://developer.mozilla.org/en-US/search?q=${encodeURIComponent(featureName)}`;

function resolveSupport(raw) {
  if (!raw) return { status: 'unknown', version: null };
  // Pick the best statement: unprefixed, no flags, actually added
  const stmt = Array.isArray(raw)
    ? (raw.find((s) => !s.prefix && !s.flags?.length && s.version_added !== false) ??
       raw[0])
    : raw;
  if (stmt.version_added === false) return { status: 'n', version: null };
  if (stmt.version_added === null) return { status: 'unknown', version: null };
  if (stmt.version_added === 'preview') return { status: 'a', version: 'preview' };
  if (stmt.flags?.length) return { status: 'a', version: String(stmt.version_added) };
  if (stmt.prefix) return { status: 'a', version: String(stmt.version_added) };
  return { status: 'y', version: String(stmt.version_added) };
}

// BCD browser key → caniuse agent key
const BCD_TO_CL = {
  chrome: 'chrome',
  chrome_android: 'and_chr',
  edge: 'edge',
  firefox: 'firefox',
  firefox_android: 'and_ff',
  safari: 'safari',
  safari_ios: 'ios_saf',
  samsunginternet_android: 'samsung',
  ie: 'ie',
  opera: 'opera',
  opera_android: 'op_mob',
  webview_android: 'android',
};

// Global usage %: sum usage for all versions >= version_added
let totalUsage = 0;
if (compat) {
  for (const [bcdKey, clKey] of Object.entries(BCD_TO_CL)) {
    const { status, version } = resolveSupport(compat.support?.[bcdKey]);
    if (status !== 'y' || !version) continue;
    const agent = usageAgents[clKey];
    if (!agent) continue;
    const since = parseFloat(version.replace(/^≤/, ''));
    for (const [v, u] of Object.entries(agent.usage_global)) {
      if (parseFloat(v) >= since) totalUsage += u;
    }
  }
}

function releaseDate(clKey, version) {
  const rd = localAgents[clKey]?.release_date;
  if (!rd) return null;
  // BCD and caniuse-lite version keys don't always match.
  // Examples:
  // - BCD "26" vs caniuse-lite "26.0"
  // - BCD "9" vs caniuse-lite range "9.0-9.2"
  const target = Number.parseFloat(version);
  const rangeKey = Number.isFinite(target)
    ? Object.keys(rd).find((k) => {
        if (!k.includes('-')) return false;
        const [startRaw, endRaw] = k.split('-', 2);
        const start = Number.parseFloat(startRaw);
        const end = Number.parseFloat(endRaw);
        if (!Number.isFinite(start) || !Number.isFinite(end)) return false;
        return target >= start && target <= end;
      })
    : undefined;
  const ts =
    rd[version] ??
    rd[`${version}.0`] ??
    rd[rangeKey ?? ''] ??
    null;
  if (!ts) return null;
  return new Date(ts * 1000).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const BROWSERS = [
  { key: 'chrome',         label: 'Chrome',      clKey: 'chrome'   },
  { key: 'edge',           label: 'Edge',         clKey: 'edge'     },
  { key: 'firefox',        label: 'Firefox',      clKey: 'firefox'  },
  { key: 'safari',         label: 'Safari',       clKey: 'safari'   },
  { key: 'safari_ios',     label: 'iOS Safari',   clKey: 'ios_saf'  },
  // Chrome for Android (and_chr) auto-updates silently, so the entire user base
  // is always on the latest version. caniuse-lite only tracks one entry for it —
  // the current version — which means there's no release_date stored for older
  // versions like "120". The version label still shows (e.g. "since 120"), but
  // the date hover swap is unavailable since the historical data simply isn't there.
  { key: 'chrome_android', label: 'Android',      clKey: 'and_chr'  },
];

const browserData = BROWSERS.map(({ key, label, clKey }) => {
  const { status, version } = resolveSupport(compat?.support?.[key]);
  let statusLabel = '';
  let versionLabel = '';
  let date = null;
  if (status === 'y' && version) {
    statusLabel = 'since';
    versionLabel = version;
    date = releaseDate(clKey, version);
  } else if (status === 'a' && version) {
    statusLabel = 'partial';
    versionLabel = version;
    date = releaseDate(clKey, version);
  } else if (status === 'n') {
    versionLabel = 'No';
  } else {
    versionLabel = 'Unknown';
  }
  return { key, label, status, statusLabel, versionLabel, date };
});
---

<div class="canIUse_wrap">
  {baselineInfo && (
    <a
      href={baselineYamlUrl}
      class={`canIUse_baseline canIUse_baseline-${baselineInfo.baseline || 'limited'}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Fragment set:html={BASELINE_ICONS[baselineInfo.baseline || 'limited']} />
      {baselineInfo.baseline === 'high' && (
        <span class="canIUse_baselineLabel">Baseline Widely available</span>
      )}
      {baselineInfo.baseline === 'low' && (
        <span class="canIUse_baselineLabel">
         Baseline {baselineInfo.year}
          <span class="canIUse_baselineBadge">New</span>
        </span>
      )}
      {baselineInfo.baseline === false && (
        <span class="canIUse_baselineLabel">Limited availability</span>
      )}
    </a>
  )}
  <div class="canIUse">
    <div class="canIUse_header">
      <span class="canIUse_feature">{featureName}</span>
      <span class="canIUse_meta">
        {compat && <span class="canIUse_usage">Usage: {Math.round(Math.round(totalUsage * 100) / 100)}%</span>}
      </span>
      <a href={mdnUrl} class="canIUse_link" target="_blank" rel="noopener noreferrer">
        <span class="canIUse_linkText">MDN</span>
        <Fragment set:html={externalLinkIcon} />
      </a>
    </div>
    <div class="canIUse_grid">
      {browserData.map(({ label, status, statusLabel, versionLabel, date }) => (
        <div class={`canIUse_browser canIUse_browser-${status}${date ? ' canIUse_browser-swappable' : ''}`}>
          <span class="canIUse_name">{label}</span>
          <span class="canIUse_version">
            {statusLabel && <small>{statusLabel}</small>}
            <span class="canIUse_versionNum">{versionLabel}</span>
            {date && <span class="canIUse_versionDate">{date}</span>}
          </span>
        </div>
      ))}
    </div>
  </div>
</div>
