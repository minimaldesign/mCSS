---
import { Image } from 'astro:assets';
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';

// Define badge type for multiple badges with customizable colors
interface Badge {
  label: string;
  color?: string; // CSS color value ('#fff', 'white') or token name ('--yes-500')
}

// Props definitions
interface Props extends HTMLAttributes<'article'> {
  variant?: 'filled' | 'raised';
  isDisabled?: boolean;
  isLoading?: boolean;
  href?: string;
  title?: string;
  subtitle?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  aspectRatio?: string;
  badges?: Badge[]; // Array of badge objects
  'data-testid'?: string;
}

// prettier-ignore
const {
  variant,
  isDisabled = false,
  isLoading = false,
  href,
  title,
  subtitle,
  imageSrc,
  imageAlt = '',
  aspectRatio = 'golden',
  badges = [],
  class: className,
  'data-testid': testId = 'card',
  ...rest
} = Astro.props as Props;

// Badge colors accept a raw CSS color or a token name ('--yes-500')
const badgeColor = (color?: string) => (color ? (color.startsWith('--') ? `var(${color})` : color) : undefined);

// Map aspect ratio to CSS value
const aspectRatioMap = {
  widescreen: 'var(--ar-widescreen)',
  landscape: 'var(--ar-landscape)',
  portrait: 'var(--ar-portrait)',
  square: 'var(--ar-square)',
  golden: 'var(--ar-golden)',
};
const aspectRatioValue = aspectRatioMap[aspectRatio];
---

<article
  class:list={[
    'card',
    {
      'card-filled': variant === 'filled',
      'card-raised': variant === 'raised',
      'is-disabled': isDisabled,
    },
    className,
  ]}
  style={`--card-aspect-ratio: ${aspectRatioValue};`}
  data-testid={testId}
  aria-disabled={isDisabled ? 'true' : undefined}
  {...rest}>
  <!-- Clickable wrapper if href is provided -->
  {href && !isDisabled && <a href={href} class="card_link" aria-label={title || 'Card link'} />}

  <!-- Header -->
  {
    (title || subtitle || badges.length > 0) && (
      <header class="card_header" data-testid="card-header">
        {(title || subtitle) && (
          <div class="card_header_text">
            {title && <h2>{title}</h2>}
            {subtitle && <p>{subtitle}</p>}
          </div>
        )}
        {badges.length > 0 && (
          <div class="card_badges" data-testid="card-badges">
            {badges.map((badge, index) => (
              <span class="badge card_badge" style={badge.color ? `--badge-background-color: ${badgeColor(badge.color)};` : ''} data-testid={`card-badge-${index}`}>
                {badge.label}
              </span>
            ))}
          </div>
        )}
      </header>
    )
  }

  <!-- Media -->
  {
    imageSrc && (
      <figure class="card_media" data-testid="card-media">
        {isLoading ? <div class="card_placeholder" /> : <Image src={imageSrc as ImageMetadata} alt={imageAlt} class="card_image" loading="lazy" decoding="async" />}
      </figure>
    )
  }

  <!-- Content -->
  <section class="card_content" data-testid="card-content">
    {
      isLoading ? (
        <div class="card_loading">
          <div class="card_loadingLine" />
          <div class="card_loadingLine card_loadingLine-short" />
        </div>
      ) : (
        <slot />
      )
    }
  </section>

  <!-- Actions: Only render footer if actions slot is provided -->
  {
    Astro.slots.has('actions') && (
      <footer class="card_actions" data-testid="card-actions">
        <slot name="actions" />
      </footer>
    )
  }
</article>
