---
import { Image } from 'astro:assets';
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';
import Avatar from './Avatar.astro';
import Tags from './Tags.astro';

// Define badge type for multiple badges with customizable colors
interface Badge {
  label: string;
  color?: string; // CSS color value ('#fff', 'white') or token name ('--yes-500')
}

// Props definitions
interface Props extends HTMLAttributes<'article'> {
  variant?: 'filled' | 'raised';
  isDisabled?: boolean;
  isLoading?: boolean;
  href?: string;
  title?: string;
  subtitle?: string;
  headingLevel?: 2 | 3 | 4;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  aspectRatio?: string;
  flushImage?: boolean;
  badges?: Badge[]; // Array of badge objects
  tags?: string[];
  tagsUrl?: string;
  author?: string;
  avatarSrc?: ImageMetadata | string;
  date?: Date;
  locale?: string;
  'data-testid'?: string;
}

// prettier-ignore
const {
  variant,
  isDisabled = false,
  isLoading = false,
  href,
  title,
  subtitle,
  headingLevel = 2,
  imageSrc,
  imageAlt = '',
  aspectRatio = 'golden',
  flushImage = false,
  badges = [],
  tags = [],
  tagsUrl = '/blog/tags',
  author,
  avatarSrc,
  date,
  locale = 'en-US',
  class: className,
  'data-testid': testId = 'card',
  ...rest
} = Astro.props as Props;

// Badge colors accept a raw CSS color or a token name ('--yes-500')
const badgeColor = (color?: string) => (color ? (color.startsWith('--') ? `var(${color})` : color) : undefined);

// Map aspect ratio to CSS value
const aspectRatioMap = {
  widescreen: 'var(--ar-widescreen)',
  landscape: 'var(--ar-landscape)',
  portrait: 'var(--ar-portrait)',
  square: 'var(--ar-square)',
  golden: 'var(--ar-golden)',
};
const aspectRatioValue = aspectRatioMap[aspectRatio];

const Heading = `h${headingLevel}` as const;

// The whole card is clickable through one stretched .card_link. When there is
// a title, the title anchor carries it so its text names the link; otherwise
// an empty labelled anchor takes over.
const linked = href && !isDisabled;
const titleLink = linked && title;
const overlayLink = linked && !title;

const dateText = date && date.toLocaleDateString(locale, { dateStyle: 'medium' });
const dateTime = date && date.toISOString().split('T')[0];
---

<article
  class:list={[
    'card',
    {
      'card-filled': variant === 'filled',
      'card-raised': variant === 'raised',
      'is-disabled': isDisabled,
    },
    className,
  ]}
  style={`--card-aspect-ratio: ${aspectRatioValue};`}
  data-testid={testId}
  aria-disabled={isDisabled ? 'true' : undefined}
  {...rest}>
  {overlayLink && <a href={href} class="card_link" aria-label="Card link" />}

  <!-- Flush media sits edge-to-edge on top of the card -->
  {
    imageSrc && flushImage && (
      <figure class="card_media card_media-flush" data-testid="card-media">
        {isLoading ? (
          <div class="card_placeholder" />
        ) : typeof imageSrc === 'string' ? (
          <img class="card_image" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
        ) : (
          <Image class="card_image" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
        )}
      </figure>
    )
  }

  {tags.length > 0 && <Tags class="card_tags" tagList={tags} url={tagsUrl} />}

  <!-- Header -->
  {
    (title || subtitle || badges.length > 0) && (
      <header class="card_header" data-testid="card-header">
        {(title || subtitle) && (
          <div class="card_header_text">
            {title && (
              <Heading class="card_title">{titleLink ? <a href={href} class="card_link">{title}</a> : title}</Heading>
            )}
            {subtitle && <p>{subtitle}</p>}
          </div>
        )}
        {badges.length > 0 && (
          <div class="card_badges" data-testid="card-badges">
            {badges.map((badge, index) => (
              <span class="badge card_badge" style={badge.color ? `--badge-background-color: ${badgeColor(badge.color)};` : ''} data-testid={`card-badge-${index}`}>
                {badge.label}
              </span>
            ))}
          </div>
        )}
      </header>
    )
  }

  <!-- Inset media -->
  {
    imageSrc && !flushImage && (
      <figure class="card_media" data-testid="card-media">
        {isLoading ? (
          <div class="card_placeholder" />
        ) : typeof imageSrc === 'string' ? (
          <img class="card_image" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
        ) : (
          <Image class="card_image" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
        )}
      </figure>
    )
  }

  <!-- Content -->
  {
    (isLoading || Astro.slots.has('default')) && (
      <section class="card_content" data-testid="card-content">
        {isLoading ? (
          <div class="card_loading">
            <div class="card_loadingLine" />
            <div class="card_loadingLine card_loadingLine-short" />
          </div>
        ) : (
          <slot />
        )}
      </section>
    )
  }

  <!-- Byline -->
  {
    (author || date) && (
      <footer class="card_byline" data-testid="card-byline">
        {author && <Avatar size="sm" imageSrc={avatarSrc}>{author}</Avatar>}
        <div>
          {author && <span class="card_author">{author}</span>}
          {date && <time datetime={dateTime}>{dateText}</time>}
        </div>
      </footer>
    )
  }

  <!-- Actions: Only render footer if actions slot is provided -->
  {
    Astro.slots.has('actions') && (
      <footer class="card_actions" data-testid="card-actions">
        <slot name="actions" />
      </footer>
    )
  }
</article>
