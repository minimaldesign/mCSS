---
import ThemeToggle from './ThemeToggle.astro';

import { getCollection } from 'astro:content';

import menuIcon from '../assets/icons/menu.svg?raw';
import closeIcon from '../assets/icons/x.svg?raw';

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.split('/')[1]; // pathname starts with '/'

import { filterAndSort } from '../scripts/utilities';
const componentList = await getCollection('components');
const atomPosts = filterAndSort(componentList, 'atom');
const componentPosts = filterAndSort(componentList, 'component');

const navItems = [
  {
    id: '',
    top: true,
    data: {
      title: 'Home',
    },
    subsection: [],
  },
  {
    id: 'docs',
    data: {
      title: 'Docs',
    },
    subsection: [
      {
        id: 'start',
        data: {
          title: 'Getting Started',
        },
      },
      {
        id: 'tokens',
        data: {
          title: 'Tokens',
        },
      },
      {
        id: 'media-queries',
        data: {
          title: 'Media Queries',
        },
      },
      {
        id: 'themes',
        data: {
          title: 'Themes',
        },
      },
      {
        id: 'reset',
        data: {
          title: 'Reset',
        },
      },
      {
        id: 'elements',
        data: {
          title: 'HTML Elements',
        },
      },
      {
        id: 'global',
        data: {
          title: 'Global Styles',
        },
      },
      {
        id: 'helpers',
        data: {
          title: 'Helpers',
        },
      },
    ],
  },
  {
    id: 'atoms',
    url: 'components',
    data: {
      title: 'Atoms',
    },
    subsection: atomPosts,
  },
  {
    id: 'components',
    data: {
      title: 'Components',
    },
    subsection: componentPosts,
  },
  {
    id: 'blog',
    top: true,
    data: {
      title: 'Blog',
    },
  },
];
---

<nav class="header_navMobile" role="navigation" aria-label="Main menu">
  <button aria-expanded="false" aria-label="Open menu">
    <Fragment set:html={menuIcon} />
  </button>
  <div>
    <div class="header_navMobile_themeToggle">
      <ThemeToggle />
    </div>
    <button aria-label="Close menu">
      <Fragment set:html={closeIcon} />
    </button>
    <ul>
      {
        navItems.map((item) => (
          <li>
            <a class:list={[{ 'is-active': item.id == currentPath }]} href={`/${item.url ? item.url : item.id}${item.top ? '' : '/start'}`}>
              {item.data.title}
            </a>
            {item.subsection && (
              <ul>
                {item.subsection.map((sub) => (
                  <li>
                    <a class:list={[{ 'is-active': sub.id == currentPath }]} href={`/${item.url ? item.url : item.id}/${sub.id}`}>
                      {sub.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script is:inline>
  (() => {
    const button = document.querySelector('.header_navMobile > button');
    const menu = document.querySelector('.header_navMobile > div');
    const closeButton = document.querySelector('.header_navMobile > div button');

    const setOpen = (open) => {
      menu.classList.toggle('is-open', open);
      menu.classList.toggle('body-is-locked', open);
      button.setAttribute('aria-expanded', String(open));
      // Move focus into the menu on open; return it to the trigger on close.
      if (open) {
        closeButton.focus();
      } else {
        button.focus();
      }
    };

    button.addEventListener('click', () => setOpen(true));
    closeButton.addEventListener('click', () => setOpen(false));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) setOpen(false);
    });
  })();
</script>
