---
import { Image } from 'astro:assets';
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';
import { getInitials } from '../scripts/utilities';

interface Props extends HTMLAttributes<'div'> {
  status?: 'online' | 'offline';
  imageSrc?: ImageMetadata | string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  'data-testid'?: string;
}

// prettier-ignore
const {
  status,
  imageSrc,
  size,
  class: className,
  'data-testid': testId = 'avatar',
  ...rest
} = Astro.props as Props;

const slotContent = await Astro.slots.render('default');
const initials = getInitials(slotContent);
const label = slotContent || 'User avatar';
---

<!-- prettier-ignore -->
<div
  class:list={[
    'avatar',
    size && `avatar-${size}`,
    status && `is-${status}`,
    className,
  ]}
  role="img"
  aria-label={label}
  data-testid={testId}
  {...rest}
>
  <div>
    {imageSrc && <Image src={imageSrc as ImageMetadata} alt={label} width="256" />}
    {!imageSrc && initials && <span>{initials}</span>}
  </div>
</div>
