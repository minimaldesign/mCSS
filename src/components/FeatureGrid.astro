---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'ul'> {
  cols?: 2 | 3 | 4;
  'data-testid'?: string;
}

// prettier-ignore
const {
  cols = 3,
  class: className,
  'data-testid': testId = 'featureGrid',
  ...rest
} = Astro.props as Props;

// The grid system's responsive column attributes (see global.grid.css)
const gridCols: Record<string, string> = { col: '1', 'col-md': '2', 'col-lg': String(cols) };
---

<!-- prettier-ignore -->
<ul
  class:list={['featureGrid', 'grid', className]}
  {...gridCols}
  data-testid={testId}
  {...rest}
>
  <slot />
</ul>
