---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  'data-testid'?: string;
}

// prettier-ignore
const {
  class: className,
  'data-testid': testId = 'faq',
  ...rest
} = Astro.props as Props;
---

<!-- prettier-ignore -->
<div
  class:list={['faq', className]}
  data-testid={testId}
  {...rest}
>
  <slot />
</div>
