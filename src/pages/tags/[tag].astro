---
import { getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const md = await createMarkdownProcessor();
const descriptions = new Map();
for (const post of posts) {
  const { code } = await md.render(post.data.description);
  descriptions.set(post.id, code);
}
---

<BaseLayout bodyClass="layout layout-centered">
  <main class="blog layout_content_main">
    <h1>Posts tagged with “{tag}”</h1>
    <ul class="blog_postListing">
      {
        posts.map((post) => (
          <li>
            <p>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </p>
            <Fragment set:html={descriptions.get(post.id)} />
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
