---
import DemoLayout from '../../../layouts/DemoLayout.astro';
---

<DemoLayout title=".layout-docs demo" bodyClass="layout layout-docs" fullBody>
  <header class="layoutDemo_region layoutDemo_region-header">header</header>
  <div class="layout_content">
    <aside class="layout_content_aside layoutDemo_region">.layout_content_aside (nav)</aside>
    <aside class="layout_content_aside layout_content_aside-toc layoutDemo_region">.layout_content_aside-toc</aside>
    <main class="layout_content_main layoutDemo_region layoutDemo_region-main">
      .layout_content_main
      <span class="layoutDemo_note">One column below --md (768px) with both asides hidden, nav + main from --md, and the TOC aside joining from --lg (1024px). Resize the window to see all three states.</span>
    </main>
  </div>
  <footer class="layoutDemo_region layoutDemo_region-footer">footer (sticky)</footer>
</DemoLayout>
