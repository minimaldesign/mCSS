---
import DemoLayout from '../../../layouts/DemoLayout.astro';
---

<DemoLayout title=".layout-centered demo" bodyClass="layout layout-centered" fullBody>
  <header class="layoutDemo_region layoutDemo_region-header">header</header>
  <div class="layout_content">
    <main class="layout_content_main layoutDemo_region layoutDemo_region-main layoutDemo_region-column">
      .layout_content_main
      <span class="layoutDemo_note">A single reading column, capped at --layout-content-width (70ch). The footer stays pinned to the bottom of short pages.</span>
    </main>
  </div>
  <footer class="layoutDemo_region layoutDemo_region-footer">footer (sticky)</footer>
</DemoLayout>
