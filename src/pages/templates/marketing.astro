---
// Marketing one-pager template: built only from the mCSS framework and
// library components. No site CSS. Copy this file, swap the copy and
// links, and delete the theme-switcher block at the bottom (docs demo
// chrome, not part of the template). The copy is deliberately in on the
// joke: the structure is the standard landing-page structure, and the
// words point at it while it happens. Replace them with yours.
import '../../styles/framework/mcss.css';
import wireframeThemeUrl from '../../styles/framework/theme.wireframe.css?url';

import Banner from '../../components/Banner.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import FeatureItem from '../../components/FeatureItem.astro';
import Testimonial from '../../components/Testimonial.astro';
import PricingCard from '../../components/PricingCard.astro';
import Faq from '../../components/Faq.astro';
import FaqItem from '../../components/FaqItem.astro';
import Footer from '../../components/Footer.astro';

import circleCheck from '../../assets/icons/circle-check.svg?raw';
import moonStar from '../../assets/icons/moon-star.svg?raw';
import externalLink from '../../assets/icons/external-link.svg?raw';
import heart from '../../assets/icons/heart.svg?raw';
import mail from '../../assets/icons/mail.svg?raw';
import rotateCcw from '../../assets/icons/rotate-ccw.svg?raw';

// The canonical three. Every one-pager has these and only these.
const navItems = [
  { label: 'Features', href: '#features' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];
---

<html lang="en">
  <head>
    <style is:inline>
      /* Pin the cascade-layer order before any stylesheet loads: layer
         priority is set by first occurrence, and the theme <link> below
         may be parsed before the framework's own @layer statement. */
      @layer settings, base, elements, global, components, theme, helpers;
    </style>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Fold: the landing page you already know how to read. A marketing one-pager template built with mCSS and its component library." />
    <title>Fold, the landing page that knows what it is</title>
    {/* media="not all" keeps the theme parked but fetchable; the switcher
        flips it to "all". A `disabled` attribute would be cleaner, but
        Chromium never loads a parser-created disabled link. */}
    <link rel="stylesheet" href={wireframeThemeUrl} media="not all" id="wireframeTheme" />
  </head>
  <body>
    <Banner>
      Fold 2.1 is out: new gradient, same product. <a href="#pricing">See what it costs</a>
    </Banner>

    <Header sticky navItems={navItems}>
      <a slot="logo" href="#"><strong>Fold</strong></a>
      <a slot="actions" class="bt bt-primary" href="#pricing">Start free</a>
    </Header>

    <main>
      <Hero variant="full" height={55} media={{ type: 'gradient', src: 'var(--gradient-primary)' }} textColor="--base-0">
        <h1>The landing page you already know how to read</h1>
        <p>Big headline, reassuring sentence underneath, two buttons where the bright one is the one we want. You've scanned this exact page four hundred times, so we won't pretend it's a surprise.</p>
        <div class="hero_actions">
          <a class="bt bt-lg bt-white" href="#pricing">Press the bright one</a>
          <a class="bt bt-lg bt-outline-white" href="#features">Or this one, quietly</a>
        </div>
      </Hero>

      <Section id="features" eyebrow="Features" title="Six features, because six fills the grid" lede="Three across, two down, one icon each. The icons took ninety seconds to pick and it shows.">
        <FeatureGrid cols={3}>
          <FeatureItem title="Accessible, genuinely">
            <Fragment slot="icon" set:html={circleCheck} />
            <p>The one claim on this page we'd defend in public. Keyboard, contrast, and focus states are handled before you write a line.</p>
          </FeatureItem>
          <FeatureItem title="Dark mode">
            <Fragment slot="icon" set:html={moonStar} />
            <p>Every product has this now. It stopped being a feature years ago. Here it is in a box with an icon anyway.</p>
          </FeatureItem>
          <FeatureItem title="No lock-in">
            <Fragment slot="icon" set:html={externalLink} />
            <p>The traditional promise of software that doesn't yet have anything to lock you into. Plain HTML and CSS, hosted wherever.</p>
          </FeatureItem>
          <FeatureItem title="Instant rollbacks">
            <Fragment slot="icon" set:html={rotateCcw} />
            <p>For the typo you're going to ship on a Friday. Every deploy is kept, so it stays a one-click problem.</p>
          </FeatureItem>
          <FeatureItem title="Human support">
            <Fragment slot="icon" set:html={mail} />
            <p>A real person replies. Currently that person is also the founder, the designer, and whoever wrote this sentence.</p>
          </FeatureItem>
          <FeatureItem title="Open source core">
            <Fragment slot="icon" set:html={heart} />
            <p>MIT licensed and developed in the open. Also the heart was the last icon left in the folder.</p>
          </FeatureItem>
        </FeatureGrid>
      </Section>

      <Section variant="filled" eyebrow="Testimonials" title="Three people said three nice things" lede="The legal minimum. Two looks desperate and four doesn't fit the grid.">
        <div class="grid" col="1" col-md="3">
          <Testimonial name="Maya Okafor" role="Freelance designer">
            <p>I rebuilt my portfolio in an afternoon and my clients think I hired someone. I have not corrected them.</p>
          </Testimonial>
          <Testimonial name="Jonas Lindqvist" role="Founder, Fika Labs">
            <p>A number went up after we switched. I'd tell you which number, but this quote is already the length they asked for.</p>
          </Testimonial>
          <Testimonial name="Priya Raman" role="Docs lead, OSS project">
            <p>They wanted two sentences. This is the second one.</p>
          </Testimonial>
        </div>
      </Section>

      <Section id="pricing" eyebrow="Pricing" title="Three tiers, and you'll pick the middle one" lede="Free, the one with the badge on it, and an expensive one whose whole job is making the badge look reasonable.">
        <div class="grid" col="1" col-md="3">
          <PricingCard name="Starter" price="$0" period="/month" description="For people who will use this forever and never pay us." features={['1 site', 'Community support', 'A subdomain with our name in it']} ctaHref="#" />
          <PricingCard name="Pro" price="$19" period="/month" description="The one with the badge. Statistically, this is you." features={['10 sites', 'Custom domains', 'Email support', 'Instant rollbacks']} ctaHref="#" highlighted badge="Popular" />
          <PricingCard name="Team" price="$79" period="/month" description="Exists so the $19 plan feels sensible." features={['Unlimited sites', 'Priority support', 'Shared workspaces', 'SSO, the enterprise checkbox']} ctaHref="#" />
        </div>
      </Section>

      <Section id="faq" eyebrow="FAQ" title="Questions we've decided you're asking" contentWrap="md">
        <Faq>
          <FaqItem question="Can I use my own domain?" name="faq" open>
            <p>Yes. Every FAQ on the internet opens with this question and the answer is always yes. We're not going to be the ones who break the streak. Paid plans get custom domains with automatic HTTPS, and the free plan gives you a subdomain with our name in it.</p>
          </FaqItem>
          <FaqItem question="What happens if I cancel?" name="faq">
            <p>Nothing dramatic. Your sites run until the end of the billing period, you can export the HTML and CSS whenever you like, and we don't hold your content hostage. This paragraph is contractually required to be reassuring, and it also happens to be true.</p>
          </FaqItem>
          <FaqItem question="Do you offer discounts?" name="faq">
            <p>Students, nonprofits, and open source projects get 50% off. Ask us and we'll say yes, because saying yes costs less than employing someone to say no.</p>
          </FaqItem>
          <FaqItem question="Is there a trial for paid plans?" name="faq">
            <p>Fourteen days, no card. The card was the part you were actually asking about.</p>
          </FaqItem>
        </Faq>
      </Section>

      <Section title="Ready to scroll back up and press the bright one?" lede="This is the closing CTA. It repeats the hero's buttons because you've forgotten them, which is precisely why every page ends this way." variant="primary">
        <div class="section_actions">
          <a class="bt bt-lg bt-white" href="#pricing">Press the bright one</a>
          <a class="bt bt-lg bt-outline-white" href="#faq">Read the FAQ again</a>
        </div>
      </Section>
    </main>

    <Footer>
      <ul>
        <li>
          <h5>Product</h5>
          <ul>
            <li><a href="#features">Features</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#faq">FAQ</a></li>
          </ul>
        </li>
        <li>
          <h5>Company</h5>
          <ul>
            <li><a href="#">About</a></li>
            <li><a href="#">Blog (two posts)</a></li>
            <li><a href="#">Contact</a></li>
          </ul>
        </li>
        <li>
          <h5>Legal</h5>
          <ul>
            <li><a href="#">Privacy</a></li>
            <li><a href="#">Terms</a></li>
          </ul>
        </li>
      </ul>
      <Fragment slot="meta">
        <p>© 2026 Fold Inc. The entire company is a placeholder. Built with <a href="https://mcss.dev">mCSS</a>.</p>
      </Fragment>
    </Footer>

    <!-- Theme switcher: docs demo chrome, not part of the template. -->
    <div class="templateThemer" role="group" aria-label="Preview theme">
      <button class="bt bt-primary" type="button" data-theme-choice="default" aria-pressed="true">Default</button>
      <button class="bt" type="button" data-theme-choice="wireframe" aria-pressed="false">Wireframe</button>
    </div>
    <style>
      .templateThemer {
        position: fixed;
        inset-block-end: var(--sm1);
        inset-inline-end: var(--sm1);
        z-index: 10;
        display: flex;
        gap: var(--xs2);
      }
    </style>
    <script>
      const link = document.getElementById('wireframeTheme') as HTMLLinkElement;
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-choice]');
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const wireframe = button.dataset.themeChoice === 'wireframe';
          link.media = wireframe ? 'all' : 'not all';
          buttons.forEach((b) => {
            const active = b === button;
            b.setAttribute('aria-pressed', String(active));
            b.classList.toggle('bt-primary', active);
          });
        });
      });
    </script>
  </body>
</html>
