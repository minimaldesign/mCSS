---
import { getCollection, type CollectionEntry } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { slugify } from '../../../scripts/utilities';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Group by slug so tags that differ only in case or spacing share one page.
  // The first spelling encountered becomes the display name.
  const bySlug = new Map<string, { name: string; posts: CollectionEntry<'blog'>[] }>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      let entry = bySlug.get(slug);
      if (!entry) {
        entry = { name: tag, posts: [] };
        bySlug.set(slug, entry);
      }
      entry.posts.push(post);
    }
  }

  return [...bySlug.entries()].map(([slug, { name, posts }]) => ({
    params: { tag: slug },
    props: {
      tagName: name,
      posts: [...new Set(posts)].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

const { tagName, posts } = Astro.props;

const md = await createMarkdownProcessor();
const descriptions = new Map();
for (const post of posts) {
  const { code } = await md.render(post.data.description);
  descriptions.set(post.id, code);
}
---

<BaseLayout title={`Posts tagged with “${tagName}” | mCSS Blog`} bodyClass="layout layout-centered">
  <main class="blog layout_content_main">
    <h1>Posts tagged with “{tagName}”</h1>
    <ul class="blog_postListing">
      {
        posts.map((post) => (
          <li>
            <p>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </p>
            <Fragment set:html={descriptions.get(post.id)} />
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
